---

<section class="py-20 px-6 bg-background">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary mb-6">
      Forhåndsvisning
    </h2>
    <p class="text-primary/70 mb-12 max-w-xl mx-auto">
      Appen viser neste avgang klar og lesbar på klokkeskjermen.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-2xl mx-auto">
      <div class="rounded-2xl bg-primary/10 border border-primary/10 overflow-hidden flex justify-center">
        <img src="/screenshots/tile.png" alt="Togavganger-tile på klokken" class="max-h-80 object-contain" />
      </div>
      <div class="rounded-2xl bg-primary/10 border border-primary/10 overflow-hidden flex justify-center">
        <img src="/screenshots/station.png" alt="Stasjonsvelger i Togavganger" class="max-h-80 object-contain" />
      </div>
      <div class="rounded-2xl bg-primary/10 border border-primary/10 overflow-hidden flex justify-center">
        <img src="/screenshots/details.png" alt="Detaljer med link til Entur app" class="max-h-80 object-contain" />
      </div>
    </div>
  </div>
</section>
